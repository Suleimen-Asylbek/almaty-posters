# .env.example

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email allowed to access /admin and the admin API routes.
# See lib/supabase/auth.ts — if unset, admin access is denied to everyone.
ADMIN_EMAIL=admin@example.com

# WhatsApp number used by every "Написать в WhatsApp" CTA (international
# format, digits only, no leading +).
NEXT_PUBLIC_WHATSAPP_NUMBER=77077124221

# Canonical site URL, used by robots.ts and sitemap.ts.
NEXT_PUBLIC_SITE_URL=https://almatyposters.kz

# Set to "true" to use fixed test data in the Hero ring instead of live
# featured products — see components/home/hero/HeroStage.
NEXT_PUBLIC_HERO_USE_TEST_DATA=false
